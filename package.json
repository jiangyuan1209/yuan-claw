{
  "name": "@jiangyuan1209/yuan-claw",
  "version": "0.1.13",
  "description": "A local CLI agent with tools, search, and interactive approval.",
  "type": "module",
  "bin": {
    "yuan-claw": "dist/cli/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiangyuan1209/yuan-claw.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/main.js",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@mozilla/readability": "^0.6.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.0.2",
    "openai": "^4.56.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
